{
  "private": true,
  "keywords": [
    "actions",
    "release",
    "helper",
    "github"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/actions-cool/release-helper.git",
    "branch": "main"
  },
  "license": "MIT",
  "author": "xrkffgg",
  "main": "src/main.ts",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "package": "ncc build src/main.ts -o dist",
    "all": "npm run format-check && npm run package",
    "tag": "node ./scripts/tag.js"
  },
  "dependencies": {
    "@actions/core": "1.2.6",
    "@actions/exec": "1.1.1",
    "@actions/github": "4.0.0",
    "actions-util": "1.0.0"
  },
  "devDependencies": {
    "@octokit/rest": "19.0.5",
    "@typescript-eslint/parser": "4.15.2",
    "@umijs/fabric": "2.6.2",
    "@vercel/ncc": "0.34.0",
    "axios": "0.21.1",
    "chalk": "4.1.2",
    "prettier": "2.2.1",
    "simple-git": "2.46.0",
    "typescript": "^4.1.2"
  }
}
